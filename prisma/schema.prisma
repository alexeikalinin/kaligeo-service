generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Client {
  id           String     @id @default(cuid())
  clientNumber Int        @unique @default(autoincrement())
  email        String     @unique
  companyName  String
  websiteUrl   String?
  createdAt    DateTime   @default(now())
  auditJobs    AuditJob[]
}

model AuditJob {
  id               String        @id @default(cuid())
  status           JobStatus     @default(PENDING)
  tier             Tier          @default(STANDARD)
  clientId         String?
  client           Client?       @relation(fields: [clientId], references: [id])
  clientEmail      String
  websiteUrl       String
  companyName      String
  niche            String
  competitors      String[]
  reportToken      String        @unique @default(cuid())
  pdfUrl           String?
  errorMessage     String?
  chatMessagesUsed  Int           @default(0)
  selectedPlatforms Platform[]
  createdAt         DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  completedAt      DateTime?
  adminNotes       String?
  paidAt           DateTime?
  source              String?
  baselineJobId       String?
  baselineJob         AuditJob?     @relation("AuditComparison", fields: [baselineJobId], references: [id])
  followUpJobs        AuditJob[]    @relation("AuditComparison")
  followUpScheduledAt DateTime?
  followUpSentAt      DateTime?
  recurringFrequency  String?       // "weekly" | "monthly" | "quarterly" | null
  queryResults        QueryResult[]
  report              Report?
}

model QueryResult {
  id               String   @id @default(cuid())
  jobId            String
  platform         Platform
  query            String
  response         String
  brandMentioned   Boolean  @default(false)
  competitors      String[]
  sources          String[]
  sentiment        String   @default("absent")
  positionScore    Int      @default(0) // 0=absent 1=first 2=early 3=middle 4=late
  sourceCategories Json?                // Record<SourceCategory, string[]>
  createdAt        DateTime @default(now())
  job              AuditJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, platform])
}

model Report {
  id               String   @id @default(cuid())
  jobId            String   @unique
  visibilityScores Json
  competitorMatrix Json
  weakPoints       Json
  actionPlan       Json
  overallScore     Int      @default(0)
  sourcesReport    Json?    // SourcesReport — top domains, by category, competitor advantage
  createdAt        DateTime @default(now())
  job              AuditJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model TelegramSession {
  chatId    String   @id
  step      String   @default("idle")
  data      Json     @default("{}")
  updatedAt DateTime @updatedAt
}

model FreemiumScan {
  id                   String   @id @default(cuid())
  websiteUrl           String
  companyName          String
  niche                String
  services             Json
  keywords             Json
  suggestedCompetitors String[]
  previewScore         Int
  emailCaptured        String?
  source               String?
  createdAt            DateTime @default(now())

  @@index([websiteUrl])
}

model Lead {
  id             String          @id @default(cuid())
  email          String?
  companyName    String
  websiteUrl     String?
  niche          String?
  city           String?
  source         String          @default("csv")
  status         LeadStatus      @default(NEW)
  enrichedEmail  String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  outreachEmails OutreachEmail[]

  @@index([status])
  @@index([niche])
}

model Campaign {
  id             String          @id @default(cuid())
  name           String
  status         CampaignStatus  @default(DRAFT)
  targetNiche    String?
  sequences      Json
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  outreachEmails OutreachEmail[]
}

model OutreachEmail {
  id         String    @id @default(cuid())
  leadId     String
  campaignId String
  subject    String
  body       String
  messageId  String?
  sentAt     DateTime?
  openedAt   DateTime?
  clickedAt  DateTime?
  createdAt  DateTime  @default(now())
  campaign   Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  lead       Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([campaignId])
}

enum JobStatus {
  PENDING
  GENERATING_QUERIES
  EXECUTING_QUERIES
  ANALYZING
  GENERATING_REPORT
  DELIVERING
  COMPLETED
  FAILED
  PENDING_PAYMENT
}

enum Tier {
  BASIC
  STANDARD
  ADVANCED
}

enum Platform {
  CHATGPT
  CLAUDE
  GEMINI
  PERPLEXITY
  DEEPSEEK
  YANDEXGPT
  GIGACHAT
  ALISA
  GROK
}

enum LeadStatus {
  NEW
  ENRICHED
  CONTACTED
  REPLIED
  CONVERTED
  UNSUBSCRIBED
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
}
